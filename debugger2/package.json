{
  "name": "debugger-vue",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "electron:install": "yarn add --dev electron@^28.0.0 electron-builder@^24.0.0",
    "electron:dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider vue-cli-service build && node electron/dev.js",
    "electron:build": "cross-env NODE_OPTIONS=--openssl-legacy-provider vue-cli-service build && node electron/dev.js --build"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/compat-data": "^7.27.5",
    "@vue/cli-plugin-babel": "^4.2.0",
    "@vue/cli-service": "^4.2.0",
    "babel-plugin-component": "^1.1.1",
    "cross-env": "^7.0.3",
    "vue-cli-plugin-element": "^1.0.1",
    "vue-template-compiler": "^2.6.11"
  },
  "build": {
    "appId": "com.cassia.debugger2",
    "productName": "Cassia Bluetooth Debug Tool v2",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/Cassia-Networks-Icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/Cassia-Networks-Icon.png"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
